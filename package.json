{
  "name": "stormfea",
  "version": "43.0.0",
  "description": "STORMFEA — FDM-aware FEA for FTC · Nordic Storm Team 5962",
  "type": "module",
  "scripts": {
    "build": "tsc && node scripts/copy-client.mjs",
    "copy:client": "node scripts/copy-client.mjs",
    "test": "vitest run && tsc && node dist/tests/solver_validation.js && node scripts/test_client_logic.mjs",
    "test:unit": "vitest run --reporter=verbose",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "start": "node dist/index.js",
    "dev": "npm run build && node dist/index.js",
    "profile:mem": "tsc && STORMFEA_PROFILE_MEMORY=1 node --expose-gc dist/tests/mem_profile.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^2.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.19.43",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9"
  }
}
